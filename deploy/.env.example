# ============================================================
# Chapuu Production Environment Configuration
# Copy this file to .env and fill in all values.
# NEVER commit the .env file to git.
# Place this file at: /opt/chapuu/chapuu-backend/deploy/.env
# ============================================================

# Django Core
SECRET_KEY=change-this-to-a-long-random-string-minimum-50-characters
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,api.yourdomain.com
ADMIN_URL=your-secret-admin-path/
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Database (PostgreSQL) — individual vars used for pg_isready health checks
DB_NAME=chapuu
DB_USER=chapuu_user
DB_PASSWORD=strong-password-here
DB_HOST=db
DB_PORT=5432
# Combined URL for dj-database-url (constructed from above)
DATABASE_URL=postgres://chapuu_user:strong-password-here@db:5432/chapuu

# Redis
REDIS_URL=redis://redis:6379/1
REDIS_CACHE_URL=redis://redis:6379/2
CELERY_BROKER_URL=redis://redis:6379/0

# Payments
ZENOPAY_WEBHOOK_SECRET=your-zenopay-webhook-secret

# Traefik / TLS
TRAEFIK_ACME_EMAIL=your@email.com
TRAEFIK_DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com

# Frontend build arg (used by docker-compose build, not runtime)
VITE_BACKEND_URL=https://api.yourdomain.com
